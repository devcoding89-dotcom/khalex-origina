
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Gaming assets including phones, laptops, and digital accounts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "costPrice": { "type": "number" },
        "stock": { "type": "number" },
        "stockAlert": { "type": "number" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "draft", "sold_out"] },
        "isFeatured": { "type": "boolean" },
        "salesCount": { "type": "number" },
        "views": { "type": "number" },
        "createdAt": { "type": "object" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase records and mission status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayId": { "type": "string" },
        "customerName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "whatsapp": { "type": "string" },
        "createdAt": { "type": "object" },
        "timeline": { "type": "array" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Personnel database for CRM",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "totalSpent": { "type": "number" },
        "orderCount": { "type": "number" },
        "lastOrderDate": { "type": "object" }
      }
    },
    "StoreSettings": {
      "title": "Store Settings",
      "description": "Global configuration for KHALEX hub",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "currencySymbol": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "taxRate": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of available gaming equipment. READ: Public, WRITE: Authenticated Admin."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Manifest of all deployments. READ: Public, WRITE: Public/Admin."
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Personnel database. READ: Admin, WRITE: Admin/Public."
    },
    "/settings/global": {
      "schema": "StoreSettings",
      "description": "Global system parameters. READ: Public, WRITE: Admin."
    }
  }
}
